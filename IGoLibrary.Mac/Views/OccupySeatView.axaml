<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:IGoLibrary.Mac.ViewModels"
             x:Class="IGoLibrary.Mac.Views.OccupySeatView"
             x:DataType="vm:OccupySeatViewModel">

    <Grid RowDefinitions="Auto,*" Margin="20">

        <!-- 顶部控制区 -->
        <StackPanel Grid.Row="0" Spacing="15">

            <!-- 标题 -->
            <TextBlock Text="即时占座"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,10"/>

            <!-- 控制按钮区 -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="刷新座位"
                        Command="{Binding RefreshSeatsCommand}"
                        Width="120"
                        Height="35"/>

                <Button Content="添加到占座列表"
                        Command="{Binding AddToReserveListCommand}"
                        Width="150"
                        Height="35"/>

                <Button Content="清空占座列表"
                        Command="{Binding ClearReserveListCommand}"
                        Width="150"
                        Height="35"/>

                <Button Content="收藏选中座位"
                        Command="{Binding SaveFavoriteSeatsCommand}"
                        Width="150"
                        Height="35"/>

                <Button Content="加载收藏座位"
                        Command="{Binding LoadFavoriteSeatsCommand}"
                        Width="150"
                        Height="35"/>
            </StackPanel>

            <!-- 占座模式选择 -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="占座模式:"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="White"/>
                <ComboBox SelectedIndex="{Binding ReserveMode}"
                          Width="150"
                          Background="#2D2D30"
                          Foreground="White"
                          BorderBrush="#3F3F46">
                    <ComboBoxItem Content="激进模式 (1秒)"/>
                    <ComboBoxItem Content="随机模式 (4-8秒)"/>
                    <ComboBoxItem Content="保守模式 (5秒)"/>
                </ComboBox>
            </StackPanel>

            <!-- 占座开关 -->
            <StackPanel Orientation="Horizontal" Spacing="15">
                <Button Content="开始占座"
                        Command="{Binding StartReserveCommand}"
                        IsEnabled="{Binding !IsReserving}"
                        Width="120"
                        Height="35"
                        Background="Green"
                        Foreground="White"/>

                <Button Content="停止占座"
                        Command="{Binding StopReserveCommand}"
                        IsEnabled="{Binding IsReserving}"
                        Width="120"
                        Height="35"
                        Background="OrangeRed"
                        Foreground="White"/>

                <TextBlock VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="White"
                           Margin="10,0,0,0">
                    <Run Text="状态: "/>
                    <Run Text="{Binding IsReserving}" FontWeight="Bold"/>
                </TextBlock>
            </StackPanel>

            <Separator Margin="0,10"/>
        </StackPanel>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" ColumnDefinitions="2*,*,2*" Margin="0,10,0,0">

            <!-- 左侧：座位列表 -->
            <Border Grid.Column="0"
                    BorderBrush="#3F3F46"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="10"
                    Background="#2D2D30"
                    Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock Text="所有座位"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"
                               DockPanel.Dock="Top"
                               Margin="0,0,0,10"/>

                    <ListBox ItemsSource="{Binding SeatList}"
                             SelectedItem="{Binding SelectedSeat}"
                             Background="#252526"
                             BorderBrush="#3F3F46"
                             BorderThickness="1">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#3F3F46"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,10"
                                        Background="{Binding BackgroundColor}">
                                    <Grid ColumnDefinitions="Auto,Auto,*">
                                        <!-- 座位号 -->
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" Width="120">
                                            <TextBlock Text="座位"
                                                       Foreground="#AAAAAA"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="White"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- 状态标签 -->
                                        <Border Grid.Column="1"
                                                Padding="12,6"
                                                CornerRadius="4"
                                                HorizontalAlignment="Left"
                                                Margin="10,0,0,0"
                                                Background="{Binding BadgeColor}">
                                            <TextBlock Text="{Binding Status}"
                                                       Foreground="White"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- 座位Key -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Key}"
                                                   Foreground="#999999"
                                                   FontSize="10"
                                                   FontFamily="Consolas,Menlo,Monaco,monospace"
                                                   VerticalAlignment="Center"
                                                   Margin="15,0,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 中间：待占座位列表 -->
            <Border Grid.Column="1"
                    BorderBrush="#3F3F46"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="10"
                    Background="#2D2D30"
                    Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock Text="待占座位"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"
                               DockPanel.Dock="Top"
                               Margin="0,0,0,10"/>

                    <ListBox ItemsSource="{Binding WaitingReserveSeats}"
                             Background="#252526"
                             BorderBrush="#3F3F46">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{Binding Name}" Foreground="White"/>
                                    <TextBlock Text="号" Foreground="White"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 右侧：运行日志 -->
            <Border Grid.Column="2"
                    BorderBrush="#3F3F46"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="10"
                    Background="#2D2D30">
                <DockPanel>
                    <TextBlock Text="运行日志"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"
                               DockPanel.Dock="Top"
                               Margin="0,0,0,10"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Background="#252526">
                        <ItemsControl ItemsSource="{Binding Logs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               FontFamily="Consolas,Menlo,Monaco,monospace"
                                               FontSize="12"
                                               Foreground="#D4D4D4"
                                               Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

        </Grid>

    </Grid>

</UserControl>
