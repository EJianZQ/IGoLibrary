<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:desktop="using:IGoLibrary.Ex.Desktop"
        x:Class="IGoLibrary.Ex.Desktop.ToastWindow"
        x:DataType="desktop:ToastWindow"
        Width="360"
        MinWidth="360"
        MaxWidth="360"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        SystemDecorations="None"
        WindowStartupLocation="Manual"
        TransparencyLevelHint="Transparent, Blur, AcrylicBlur, None"
        TransparencyBackgroundFallback="Transparent"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="False">
  <Border Margin="10"
          CornerRadius="18"
          Background="{DynamicResource AppToastSurfaceBrush}"
          BorderBrush="{DynamicResource AppToastBorderBrush}"
          BorderThickness="1"
          BoxShadow="0 12 32 0 #220F172A"
          ClipToBounds="True"
          PointerPressed="OnToastPointerPressed">
    <Grid RowDefinitions="Auto,4">
      <Grid ColumnDefinitions="Auto,*"
            ColumnSpacing="14"
            Margin="18,16,18,14">
        <Border Width="34"
                Height="34"
                CornerRadius="17"
                Background="{Binding AccentSoftBrush}"
                VerticalAlignment="Top"
                Margin="0,2,0,0">
          <TextBlock Text="{Binding BadgeText}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="15"
                     FontWeight="Bold"
                     Foreground="{Binding AccentBrush}" />
        </Border>

        <StackPanel Grid.Column="1"
                    Spacing="6">
          <TextBlock Text="{Binding TitleText}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="{DynamicResource AppToastTitleBrush}"
                     TextWrapping="Wrap" />
          <TextBlock Text="{Binding MessageText}"
                     FontSize="13"
                     Foreground="{DynamicResource AppToastMessageBrush}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Grid>

      <ProgressBar x:Name="LifetimeProgressBar"
                   Grid.Row="1"
                   Margin="1,0,1,1"
                   Minimum="0"
                   Maximum="1"
                   Value="1"
                   Height="3"
                   CornerRadius="0,0,17,17"
                   ShowProgressText="False"
                   IsHitTestVisible="False"
                   Foreground="{Binding AccentBrush}"
                   Background="{Binding AccentSoftBrush}" />
    </Grid>
  </Border>
</Window>
