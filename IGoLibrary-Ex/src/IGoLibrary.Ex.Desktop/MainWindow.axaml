<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:IGoLibrary.Ex.Desktop.ViewModels"
        mc:Ignorable="d"
        x:Class="IGoLibrary.Ex.Desktop.MainWindow"
        x:Name="MainWindowRoot"
        x:DataType="vm:MainWindowViewModel"
        Title="IGoLibrary-Ex"
        Width="1188"
        Height="774"
        MinWidth="1000"
        MinHeight="680"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="40"
        TransparencyLevelHint="Mica, AcrylicBlur, None"
        Background="Transparent"
        Icon="/Assets/main.ico">

  <Window.Resources>
    <PathGeometry x:Key="IconHome">M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z</PathGeometry>
    <PathGeometry x:Key="IconLogin">M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z</PathGeometry>
    <PathGeometry x:Key="IconGrab">M7 2v11h3v9l7-12h-4l4-8z</PathGeometry>
    <PathGeometry x:Key="IconOccupy">M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z M12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z</PathGeometry>
    <PathGeometry x:Key="IconSettings">M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.06-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.73,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.06,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.43-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.49-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z</PathGeometry>

  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock.page-title">
      <Setter Property="FontSize" Value="32" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextPrimaryBrush}" />
      <Setter Property="Margin" Value="0,0,0,24" />
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextPrimaryBrush}" />
      <Setter Property="Opacity" Value="0.8" />
      <Setter Property="Margin" Value="0,0,0,12" />
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource SemiCardBackgroundBrush}" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="24" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource SemiCardBorderBrush}" />
    </Style>
    <Style Selector="ListBox.sidebar ListBoxItem">
      <Setter Property="Padding" Value="16,12" />
      <Setter Property="Margin" Value="16,4" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Border.semi-card">
      <Setter Property="Background" Value="{DynamicResource SemiCardBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SemiCardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="20" />
      <Setter Property="Padding" Value="24" />
    </Style>
    <Style Selector="TextBlock.semi-section-caption">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextTertiaryBrush}" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>
    <Style Selector="TextBlock.hero-title">
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextPrimaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.hero-meta">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiAccentBrush}" />
    </Style>
    <Style Selector="TextBlock.helper-text">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextSecondaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.field-label">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextSecondaryBrush}" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>
    <Style Selector="Border.grab-stat-card">
      <Setter Property="Background" Value="{DynamicResource SemiCardBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SemiCardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="20" />
    </Style>
    <Style Selector="TextBlock.grab-stat-title">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextTertiaryBrush}" />
    </Style>
    <Style Selector="TextBlock.grab-stat-value">
      <Setter Property="FontSize" Value="28" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextPrimaryBrush}" />
    </Style>
    <Style Selector="Border.dashboard-card">
      <Setter Property="Background" Value="{DynamicResource DashboardSurfaceBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="28" />
      <Setter Property="Padding" Value="22" />
    </Style>
    <Style Selector="TextBlock.dashboard-eyebrow">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextTertiaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.dashboard-hero-title">
      <Setter Property="FontSize" Value="30" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextPrimaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="LineHeight" Value="38" />
    </Style>
    <Style Selector="TextBlock.dashboard-hero-subtitle">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextSecondaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="LineHeight" Value="24" />
    </Style>
    <Style Selector="TextBlock.dashboard-clock-date">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextSecondaryBrush}" />
    </Style>
    <Style Selector="TextBlock.dashboard-clock-time">
      <Setter Property="FontSize" Value="36" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.dashboard-card-title">
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextPrimaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.dashboard-stat-value">
      <Setter Property="FontSize" Value="30" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextPrimaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.dashboard-detail">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextSecondaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="LineHeight" Value="20" />
    </Style>
    <Style Selector="TextBlock.dashboard-ticket-seat">
      <Setter Property="FontSize" Value="60" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.dashboard-ticket-caption">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextTertiaryBrush}" />
    </Style>
    <Style Selector="TextBlock.dashboard-ticket-body">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource SemiTextPrimaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="Border.dashboard-info-row">
      <Setter Property="Background" Value="{DynamicResource DashboardMutedSurfaceBrush}" />
      <Setter Property="CornerRadius" Value="20" />
      <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="Border.notify-toggle-card">
      <Setter Property="Background" Value="{DynamicResource DashboardMutedSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SemiCardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="22" />
      <Setter Property="Padding" Value="18" />
    </Style>
    <Style Selector="Button.notification-segment">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="MinHeight" Value="42" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Opacity" Value="0.92" />
    </Style>
    <Style Selector="Button.notification-segment:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.notification-segment:pressed">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.notification-segment /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="CornerRadius" Value="999" />
    </Style>
    <Style Selector="Button.notification-segment:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppInteractiveHoverBrush}" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Button.notification-segment:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppInteractivePressedBrush}" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
  </Window.Styles>

  <Window.DataTemplates>
    <DataTemplate x:DataType="vm:SidebarNavigationItem">
      <StackPanel Orientation="Horizontal" Spacing="16">
        <PathIcon Data="{Binding IconPathData}" Width="18" Height="18" Opacity="0.8"/>
        <TextBlock Text="{Binding Title}" FontSize="15" VerticalAlignment="Center"/>
      </StackPanel>
    </DataTemplate>
    <DataTemplate x:DataType="vm:SeatItemViewModel">
      <Grid Width="52"
            Height="52"
            Margin="3"
            ClipToBounds="False"
            IsVisible="{Binding IsFilterVisible}">
        <ToolTip.Tip>
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding SeatName, StringFormat=座位 {0}}" FontWeight="Bold" />
            <TextBlock Text="{Binding SeatKey}" Classes="helper-text" />
            <TextBlock Text="{Binding StatusText, StringFormat=状态：{0}}" Classes="helper-text" />
          </StackPanel>
        </ToolTip.Tip>

        <Border CornerRadius="12"
                Background="{DynamicResource SemiColorFill0}"
                BorderThickness="1.5"
                BorderBrush="{DynamicResource SemiSuccessTextBrush}"
                IsVisible="{Binding IsAvailable}" />

        <Border CornerRadius="12"
                Background="{DynamicResource SemiColorFill2}"
                BorderThickness="1"
                BorderBrush="{DynamicResource SemiCardBorderBrush}"
                IsVisible="{Binding IsUnavailable}" />

        <Border CornerRadius="12"
                Background="{DynamicResource SemiAccentSoftBrush}"
                BorderThickness="2"
                BorderBrush="{DynamicResource SemiAccentBrush}"
                IsVisible="{Binding IsSelected}" />

        <TextBlock Text="{Binding SeatName}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="15"
                   FontWeight="Bold"
                   Foreground="{Binding IsUnavailable, Converter={x:Static BoolConverters.Not}, FallbackValue={DynamicResource SemiColorText0}}" />

        <Path Width="18"
              Height="18"
              Margin="0,-4,-4,0"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Fill="{DynamicResource AppFavoriteFillBrush}"
              Stroke="{DynamicResource AppFavoriteStrokeBrush}"
              StrokeThickness="1"
              Stretch="Fill"
              IsVisible="{Binding IsFavorite}"
              Data="M12 2.2L14.9 8.07L21.38 9.01L16.69 13.58L17.8 20.03L12 16.98L6.2 20.03L7.31 13.58L2.62 9.01L9.1 8.07Z" />

        <ToggleButton IsChecked="{Binding IsSelected}"
                      Background="Transparent"
                      BorderThickness="0"
                      Opacity="0.01"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />
      </Grid>
    </DataTemplate>
    <DataTemplate x:DataType="vm:LogLineViewModel">
      <TextBlock Margin="0,0,0,8"
                 FontFamily="Consolas, Cascadia Mono, Monaco, monospace"
                 FontSize="12.5"
                 LineHeight="20"
                 TextWrapping="Wrap">
        <Run Text="{Binding TimestampText}" Foreground="{DynamicResource SemiColorText2}" />
        <Run Text=" " />
        <Run Text="{Binding Message}" Foreground="{Binding MessageBrush}" />
      </TextBlock>
    </DataTemplate>
  </Window.DataTemplates>

  <Grid ColumnDefinitions="232,*">
    
    <!-- Sidebar -->
    <Border Grid.Column="0"
            Background="{DynamicResource AppSidebarBrush}"
            BorderBrush="{DynamicResource AppSidebarBorderBrush}"
            BorderThickness="0,0,1,0">
      <Grid RowDefinitions="40, *, Auto">
        <!-- Window Title / Drag Area -->
        <TextBlock Grid.Row="0" Text="IGoLibrary-Ex 端" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="24,0,0,0" Opacity="0.7" IsHitTestVisible="False"/>
        
        <!-- Navigation Menu -->
        <ListBox Grid.Row="1"
                 Classes="sidebar"
                 ItemsSource="{Binding SidebarItems}"
                 SelectedItem="{Binding SelectedSidebarItem}"
                 Margin="0,16,0,0"
                 Background="Transparent"
                 BorderThickness="0" />
        
        <!-- Bottom Info -->
        <StackPanel Grid.Row="2" Margin="24,24,24,32" Spacing="8">
          <TextBlock Text="当前状态" FontSize="12" Opacity="0.5" FontWeight="Bold"/>
          <TextBlock Text="{Binding SessionSummary}" FontSize="13" TextWrapping="Wrap" Opacity="0.8"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Content Area -->
    <Grid Grid.Column="1"
          RowDefinitions="40, *">
      <!-- Top drag area for content pane -->
      <Border Grid.Row="0"
              Background="{DynamicResource SemiPageBrush}"
              IsHitTestVisible="False" />
      <Border Grid.Row="1"
              Background="{DynamicResource SemiPageBrush}"
              IsHitTestVisible="False" />
      
      <!-- Views -->
      <Carousel Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" Margin="24,8,24,24">
        <Carousel.PageTransition>
          <CrossFade Duration="0:0:0.25" />
        </Carousel.PageTransition>
        
        <!-- Tab 0: Home -->
        <ScrollViewer>
          <StackPanel Spacing="18" Margin="0,0,16,0">
            <Border Classes="dashboard-card Shadow"
                    Background="{DynamicResource DashboardHeroBrush}"
                    Padding="22,20">
              <Grid ColumnDefinitions="1.55*,0.95*" ColumnSpacing="22">
                <StackPanel Spacing="14">
                  <Border Background="{DynamicResource AppAccentPanelBrush}"
                          BorderBrush="{DynamicResource AppAccentPanelBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="999"
                          Padding="12,5"
                          HorizontalAlignment="Left">
                    <TextBlock Classes="dashboard-eyebrow"
                               Foreground="{DynamicResource SemiAccentBrush}"
                               Text="个人专属仪表盘" />
                  </Border>

                  <StackPanel Spacing="6"
                              MaxWidth="580">
                    <TextBlock Classes="dashboard-hero-title"
                               Text="{Binding HomeGreetingTitleText}" />
                    <TextBlock Classes="dashboard-hero-subtitle"
                               Text="{Binding HomeGreetingMessageText}" />
                  </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{DynamicResource DashboardTimeCardBrush}"
                        CornerRadius="24"
                        Padding="18"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                  <StackPanel Spacing="10">
                    <TextBlock Classes="dashboard-clock-date"
                               Text="{Binding HomeDateText}" />
                    <TextBlock Classes="dashboard-clock-time"
                               Text="{Binding HomeTimeText}" />

                    <Border Background="{Binding HomeHeroStatusBackgroundBrush}"
                            CornerRadius="999"
                            Padding="12,8"
                            HorizontalAlignment="Left">
                      <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Ellipse Width="10"
                                 Height="10"
                                 Fill="{Binding HomeHeroStatusBrush}" />
                        <StackPanel Spacing="2">
                          <TextBlock Text="{Binding HomeHeroStatusText}"
                                     FontSize="13"
                                     FontWeight="SemiBold"
                                     Foreground="{Binding HomeHeroStatusBrush}" />
                          <TextBlock Text="{Binding HomeHeroStatusDetailText}"
                                     FontSize="12"
                                     Foreground="{DynamicResource SemiTextSecondaryBrush}"
                                     MaxWidth="240"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>
              </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20">
              <Border Classes="dashboard-card Shadow" Padding="20">
                <StackPanel Spacing="12">
                  <TextBlock Classes="dashboard-eyebrow" Text="当前锁定场馆" />
                  <TextBlock Classes="dashboard-card-title"
                             Text="{Binding HomeLockedVenueTitle}" />
                  <Border Background="{Binding HomeLockedVenueStateBackgroundBrush}"
                          CornerRadius="999"
                          Padding="12,7"
                          HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <Ellipse Width="8"
                               Height="8"
                               Fill="{Binding HomeLockedVenueStateBrush}" />
                      <TextBlock Text="{Binding HomeLockedVenueStateText}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Foreground="{Binding HomeLockedVenueStateBrush}" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>

              <Border Grid.Column="1" Classes="dashboard-card Shadow" Padding="20">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="10"
                      MinHeight="98">
                  <TextBlock Classes="dashboard-eyebrow" Text="历史成功次数" />
                  <TextBlock Classes="dashboard-stat-value"
                             Grid.Row="1"
                             VerticalAlignment="Center"
                             Text="{Binding HomeHistoricalSuccessCount}" />
                </Grid>
              </Border>

              <Border Grid.Column="2" Classes="dashboard-card Shadow" Padding="20">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="10"
                      MinHeight="98">
                  <TextBlock Classes="dashboard-eyebrow" Text="累计守护时长" />
                  <TextBlock Classes="dashboard-stat-value"
                             Grid.Row="1"
                             VerticalAlignment="Center"
                             Text="{Binding HomeTotalGuardDurationText}" />
                </Grid>
              </Border>
            </Grid>

            <Grid ColumnDefinitions="1.65*,1*" ColumnSpacing="24">
              <Border Classes="dashboard-card Shadow"
                      Background="{DynamicResource DashboardTicketBrush}"
                      MinHeight="242"
                      Padding="22,20">
                <Grid>
                  <Grid IsVisible="{Binding HasCurrentReservation}"
                        RowDefinitions="Auto,*,Auto"
                        RowSpacing="18">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                      <TextBlock Classes="dashboard-eyebrow"
                                 Text="当前预约"
                                 VerticalAlignment="Center" />

                      <Border Background="{Binding HomeReservationBadgeBackgroundBrush}"
                              CornerRadius="999"
                              Padding="12,6"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                          <Ellipse Width="8"
                                   Height="8"
                                   Fill="{Binding HomeReservationBadgeBrush}" />
                          <TextBlock Text="{Binding HomeReservationBadgeText}"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     Foreground="{Binding HomeReservationBadgeBrush}" />
                        </StackPanel>
                      </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="128,*"
                          ColumnSpacing="20"
                          VerticalAlignment="Stretch">
                      <StackPanel Spacing="2"
                                  VerticalAlignment="Stretch"
                                  HorizontalAlignment="Left">
                        <TextBlock Classes="dashboard-ticket-seat"
                                   Text="{Binding HomeReservationSeatNumberText}" />
                        <TextBlock Classes="dashboard-ticket-caption"
                                   Text="座位号" />
                      </StackPanel>

                      <StackPanel Grid.Column="1"
                                  Spacing="10"
                                  VerticalAlignment="Center">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SemiTextPrimaryBrush}">
                          <Run Text="场馆名称：" />
                          <Run Text="{Binding HomeReservationVenueText}" />
                        </TextBlock>

                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SemiTextPrimaryBrush}">
                          <Run Text="当前有效至：" />
                          <Run Text="{Binding HomeReservationExpirationTimeText}" />
                        </TextBlock>

                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SemiTextPrimaryBrush}">
                          <Run Text="剩余时间：" />
                          <Run Text="{Binding HomeReservationRemainingText}" />
                        </TextBlock>
                      </StackPanel>
                    </Grid>

                    <Button Grid.Row="2"
                            Content="取消当前预约"
                            Classes="Danger"
                            Command="{Binding CancelCurrentReservationCommand}"
                            IsEnabled="{Binding CanCancelCurrentReservation}"
                            HorizontalAlignment="Right"
                            HorizontalContentAlignment="Center"
                            MinWidth="152" />
                  </Grid>

                  <StackPanel IsVisible="{Binding HasNoCurrentReservation}"
                              Spacing="12"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center">
                    <Border Width="54"
                            Height="54"
                            CornerRadius="27"
                            Background="{DynamicResource AppNeutralIconSurfaceBrush}"
                            BorderBrush="{DynamicResource AppNeutralIconBorderBrush}"
                            BorderThickness="1">
                      <PathIcon Data="{StaticResource IconOccupy}"
                                Width="28"
                                Height="28"
                                Foreground="{DynamicResource SemiAccentBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="当前暂无预约记录"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SemiTextPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="去配置一个新任务吧，首页会在这里展示最新的预约状态与生效结果。"
                               Classes="dashboard-detail"
                               MaxWidth="380"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                  </StackPanel>
                </Grid>
              </Border>

              <Border Grid.Column="1"
                      Classes="dashboard-card Shadow"
                      MinHeight="242"
                      Padding="20">
                <StackPanel Spacing="12">
                  <TextBlock Classes="dashboard-eyebrow" Text="系统信息" />

                  <Border Classes="dashboard-info-row">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="dashboard-ticket-caption" Text="核心引擎" />
                      <TextBlock FontSize="18"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource SemiTextPrimaryBrush}"
                                 Text="{Binding HomeEngineSummaryText}"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>

                  <Border Classes="dashboard-info-row">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="dashboard-ticket-caption" Text="内存占用" />
                      <TextBlock FontSize="18"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource SemiTextPrimaryBrush}"
                                 Text="{Binding HomeMemoryUsageText}" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </ScrollViewer>

        <!-- Tab 1: Login -->
        <ScrollViewer>
          <Grid RowDefinitions="Auto,*"
                RowSpacing="16"
                Margin="0,0,16,0"
                Background="Transparent">
            <TextBlock Classes="page-title" Text="账户与场馆" />
            <Grid Grid.Row="1" ColumnDefinitions="2*,3*" ColumnSpacing="16" Background="Transparent">
              <Border Classes="semi-card Shadow" Grid.Column="0" VerticalAlignment="Top">
                <StackPanel Spacing="16">
                  <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <TextBlock Text="授权"
                              FontSize="22"
                              FontWeight="Bold"
                              VerticalAlignment="Center" />
                    <Border Grid.Column="1"
                            Theme="{DynamicResource TagLabel}"
                            Classes="Green"
                            IsVisible="{Binding IsAuthorized}">
                      <TextBlock Text="已授权" />
                    </Border>
                    <Border Grid.Column="2"
                            Theme="{DynamicResource TagLabel}"
                            Classes="Grey"
                            IsVisible="{Binding IsUnauthorized}">
                      <TextBlock Text="未授权" />
                    </Border>
                  </Grid>

                  <TextBlock Text="{Binding SessionSummary}" Classes="helper-text" />

                  <StackPanel Spacing="16" IsVisible="{Binding IsUnauthorized}">
                    <Border Background="{DynamicResource SemiColorFill0}"
                            BorderBrush="{DynamicResource SemiCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="20">
                      <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <Image Source="/Assets/qrcode.png"
                              MaxWidth="208"
                              MaxHeight="208"
                              Stretch="Uniform"
                              HorizontalAlignment="Center" />
                        <TextBlock Text="微信扫一扫获取授权链接"
                                  Classes="helper-text"
                                  HorizontalAlignment="Center"
                                  TextAlignment="Center" />
                      </StackPanel>
                    </Border>

                    <StackPanel Spacing="8">
                      <TextBlock Classes="field-label" Text="授权链接" />
                      <TextBox Watermark="在此粘贴包含 code 的链接..." Text="{Binding QrLinkText}" />
                      <CheckBox Content="记住会话"
                                IsChecked="{Binding RememberSession}"
                                HorizontalAlignment="Right" />
                    </StackPanel>

                    <Button Content="从链接解析"
                            Command="{Binding GetCookieFromLinkCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Background="{DynamicResource AppAccentBrush}"
                            Foreground="{DynamicResource AppAccentForegroundBrush}"
                            FontWeight="Bold" />
                  </StackPanel>

                  <StackPanel Spacing="12"
                              IsVisible="{Binding IsAuthorized}"
                              HorizontalAlignment="Center">
                    <TextBlock Text="✓"
                              FontSize="56"
                              FontWeight="Bold"
                              Foreground="{DynamicResource SemiSuccessTextBrush}"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="当前已成功授权"
                              FontSize="24"
                              FontWeight="Bold"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="如需切换账号，可先注销再重新扫码授权"
                              Classes="helper-text"
                              TextAlignment="Center"
                              MaxWidth="260" />
                    <Button Content="注销授权 / 重新授权"
                            Command="{Binding SignOutCommand}"
                            Classes="Danger"
                            MinWidth="160"
                            HorizontalAlignment="Center"
                            HorizontalContentAlignment="Center" />
                  </StackPanel>

                  <Expander IsExpanded="False">
                    <Expander.Header>
                      <TextBlock Text="高级：手动填写 Cookie" FontWeight="SemiBold" />
                    </Expander.Header>
                    <StackPanel Margin="0,16,0,0" Spacing="16">
                      <TextBox Watermark="如有需要可自行抓包并在此手动粘贴完整 Cookie..."
                              Text="{Binding ManualCookieText}"
                              Margin="0,8,0,0"
                              AcceptsReturn="True"
                              MinHeight="96"
                              TextWrapping="Wrap" />
                      <Button Content="验证有效性"
                              Command="{Binding ValidateManualCookieCommand}"
                              Classes="Secondary"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Center" />
                    </StackPanel>
                  </Expander>
                </StackPanel>
              </Border>

              <Border Grid.Column="1"
                      Classes="semi-card Shadow"
                      IsEnabled="{Binding IsAuthorized}"
                      VerticalAlignment="Stretch">
                <Grid>
                  <StackPanel Spacing="16">
                    <TextBlock Text="场馆配置"
                              FontSize="22"
                              FontWeight="Bold" />
                    <TextBlock Text="通过看板切换候选场馆，再用下方操作正式锁定"
                              Classes="helper-text" />

                    <Border Padding="24,16,24,24"
                            CornerRadius="16"
                            Background="{DynamicResource SemiAccentGlowBrush}"
                            BorderBrush="{DynamicResource SemiCardBorderBrush}"
                            BorderThickness="1">
                    <Grid ColumnDefinitions="*,Auto"
                            RowDefinitions="Auto,Auto"
                            ColumnSpacing="32"
                            RowSpacing="18">
                      <StackPanel Margin="16,8,16,16"
                                  VerticalAlignment="Center"
                                  Spacing="8">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Padding="10,4"
                                    CornerRadius="999"
                                    Background="{DynamicResource SemiSuccessSoftBrush}"
                                    IsVisible="{Binding ShowVenueOpenStatusTag}">
                              <TextBlock Text="{Binding VenueStatusText}"
                                         FontSize="12"
                                         FontWeight="SemiBold"
                                         Foreground="{DynamicResource SemiSuccessTextBrush}" />
                            </Border>
                            <Border Padding="10,4"
                                    CornerRadius="999"
                                    Background="{DynamicResource SemiColorFill0}"
                                    IsVisible="{Binding ShowVenueClosedStatusTag}">
                              <TextBlock Text="{Binding VenueStatusText}"
                                         FontSize="12"
                                         FontWeight="SemiBold"
                                         Foreground="{DynamicResource SemiColorText2}" />
                            </Border>
                            <Border Padding="10,4"
                                    CornerRadius="999"
                                    Background="{DynamicResource SemiSuccessSoftBrush}"
                                    IsVisible="{Binding IsCurrentLocked}">
                              <TextBlock Text="{Binding CurrentVenueLockStateText}"
                                         FontSize="12"
                                         FontWeight="SemiBold"
                                         Foreground="{DynamicResource SemiSuccessTextBrush}" />
                            </Border>
                            <Border Padding="10,4"
                                    CornerRadius="999"
                                    IsVisible="{Binding ShowVenuePreviewStateTag}"
                                    Background="{DynamicResource SemiWarningSoftBrush}"
                                    BorderBrush="{DynamicResource AppWarningBorderBrush}"
                                    BorderThickness="1">
                              <TextBlock Text="{Binding CurrentVenueLockStateText}"
                                         FontSize="12"
                                         FontWeight="SemiBold"
                                         Foreground="{DynamicResource SemiWarningTextBrush}" />
                            </Border>
                          </StackPanel>
                          <TextBlock Text="{Binding VenueName}"
                                     FontSize="24"
                                     FontWeight="Bold"
                                     Margin="0,4,0,0"
                                     TextWrapping="NoWrap"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding VenueFloor, StringFormat=楼层 · {0}}"
                                     FontSize="14"
                                     Foreground="{DynamicResource SemiColorText2}"
                                     Margin="0,8,0,0"
                                     TextWrapping="NoWrap"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock FontSize="13"
                                     Foreground="{DynamicResource SemiColorText2}"
                                     Margin="0,8,0,0"
                                     TextWrapping="NoWrap"
                                     TextTrimming="CharacterEllipsis">
                            <Run Text="开馆 · " />
                            <Run Text="{Binding VenueOpenTimeText}" />
                            <Run Text="    闭馆 · " />
                            <Run Text="{Binding VenueCloseTimeText}" />
                          </TextBlock>
                      </StackPanel>

                      <Button Grid.Column="1"
                              Grid.Row="0"
                              Command="{Binding RefreshSeatsCommand}"
                              IsVisible="{Binding IsCurrentLocked}"
                              Classes="Tertiary compact-icon"
                              Background="Transparent"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center"
                              ToolTip.Tip="刷新当前锁定场馆信息">
                        <PathIcon Data="M17.65 6.35C16.2 4.9 14.21 4 12 4V1L7 6l5 5V7c2.76 0 5 2.24 5 5 0 .65-.13 1.27-.36 1.84l1.46 1.46C18.68 14.27 19 13.17 19 12c0-2.21-.9-4.2-2.35-5.65zM6.35 17.65C7.8 19.1 9.79 20 12 20v3l5-5-5-5v4c-2.76 0-5-2.24-5-5 0-.65.13-1.27.36-1.84L5.9 8.7C5.32 9.73 5 10.83 5 12c0 2.21.9 4.2 2.35 5.65z"
                                  Width="22"
                                  Height="20"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource AppAccentBrush}" />
                      </Button>

                        <StackPanel Grid.Column="1"
                                    Grid.RowSpan="2"
                                    MinWidth="132"
                                    Spacing="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom">
                          <TextBlock Text="剩余座位"
                                    FontSize="12"
                                    Foreground="{DynamicResource SemiColorText2}"
                                    HorizontalAlignment="Right" />
                          <TextBlock Text="{Binding VenueAvailableSeatsText}"
                                    FontSize="56"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource AppAccentBrush}"
                                    HorizontalAlignment="Right" />
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Spacing="16"
                                    HorizontalAlignment="Left">
                          <Button Content="更换当前场馆..."
                                  Command="{Binding OpenVenuePickerCommand}"
                                  Background="{DynamicResource AppAccentSoftBrush}"
                                  BorderBrush="{DynamicResource AppAccentPanelBorderBrush}"
                                  BorderThickness="1"
                                  Foreground="{DynamicResource AppAccentBrush}"
                                  FontWeight="SemiBold"
                                  MinWidth="148"
                                  IsVisible="{Binding ShowVenueChangeButton}"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Center" />
                          <Button Content="取消预览 (恢复原锁定)"
                                  Command="{Binding CancelVenuePreviewCommand}"
                                  Classes="Secondary"
                                  MinWidth="180"
                                  IsVisible="{Binding ShowVenueCancelPreviewButton}"
                                  IsEnabled="{Binding CanCancelVenuePreview}"
                                  HorizontalAlignment="Left"
                                  HorizontalContentAlignment="Center" />
                        </StackPanel>
                      </Grid>
                    </Border>

                    <Button Content="{Binding LockVenueButtonText}"
                            Command="{Binding BindSelectedLibraryCommand}"
                            MinWidth="140"
                            IsVisible="{Binding IsCurrentPreview}"
                            HorizontalAlignment="Right"
                            HorizontalContentAlignment="Center"
                            Background="{DynamicResource AppAccentBrush}"
                            Foreground="{DynamicResource AppAccentForegroundBrush}"
                            FontWeight="Bold" />
                    <Button Content="{Binding LockVenueButtonText}"
                            MinWidth="140"
                            IsVisible="{Binding IsCurrentLocked}"
                            IsEnabled="False"
                            HorizontalAlignment="Right"
                            HorizontalContentAlignment="Center"
                            Background="{DynamicResource SemiColorFill0}"
                            BorderBrush="{DynamicResource SemiCardBorderBrush}"
                            BorderThickness="1"
                            Foreground="{DynamicResource SemiColorText2}"
                            FontWeight="Bold" />
                  </StackPanel>

                </Grid>
              </Border>
            </Grid>
          </Grid>
        </ScrollViewer>

          <!-- Tab 2: Grab -->
          <Grid RowDefinitions="Auto,Auto,*"
                RowSpacing="16"
                Margin="0,0,16,0"
                Background="Transparent">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="16">
              <StackPanel Spacing="4">
                <TextBlock Classes="page-title"
                           Text="抢座"
                           Margin="0" />
              </StackPanel>

              <Border Grid.Column="1"
                      Padding="14,10"
                      CornerRadius="16"
                      Background="{DynamicResource SemiAccentGlowBrush}"
                      BorderBrush="{DynamicResource SemiCardBorderBrush}"
                      BorderThickness="1"
                      VerticalAlignment="Center">
                <StackPanel Spacing="2">
                  <TextBlock Text="当前锁定场馆"
                             Classes="grab-stat-title" />
                  <TextBlock Text="{Binding BoundLibraryTitle}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource SemiTextPrimaryBrush}" />
                </StackPanel>
              </Border>
            </Grid>

            <Border Grid.Row="1"
                    Classes="semi-card Shadow"
                    Padding="20">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="24">
                <StackPanel Spacing="18">
                  <StackPanel Spacing="8">
                    <TextBlock Text="任务配置"
                               FontSize="18"
                               FontWeight="Bold" />
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="14">
                      <Button Content="🎯 选择目标座位"
                              Command="{Binding OpenGrabSeatSelectionOverlayCommand}"
                              IsEnabled="{Binding CanEditGrabConfiguration}"
                              Background="{DynamicResource AppAccentBrush}"
                              Foreground="{DynamicResource AppAccentForegroundBrush}"
                              FontWeight="Bold"
                              MinWidth="160"
                              HorizontalContentAlignment="Center"
                              VerticalAlignment="Top" />

                      <Border Grid.Column="1"
                              Background="{DynamicResource SemiColorFill0}"
                              BorderBrush="{DynamicResource SemiCardBorderBrush}"
                              BorderThickness="1"
                              CornerRadius="16"
                              Padding="12">
                        <Grid>
                          <ItemsControl ItemsSource="{Binding SelectedSeats}"
                                        IsVisible="{Binding HasSelectedSeats}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Margin="0,0,8,8"
                                        Padding="10,6"
                                        CornerRadius="999"
                                        Background="{DynamicResource SemiAccentSoftBrush}"
                                        BorderBrush="{DynamicResource SemiCardBorderBrush}"
                                        BorderThickness="1">
                                  <StackPanel Orientation="Horizontal"
                                              Spacing="8">
                                    <TextBlock Text="{Binding SeatName}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource SemiAccentBrush}" />
                                    <Button Content="✕"
                                            Command="{Binding DataContext.RemoveSelectedSeatCommand, ElementName=MainWindowRoot}"
                                            CommandParameter="{Binding .}"
                                            Classes="chip-close"
                                            IsEnabled="{Binding DataContext.CanEditGrabConfiguration, ElementName=MainWindowRoot}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource SemiAccentBrush}"
                                            FontSize="11"
                                            FontWeight="Bold"
                                            VerticalAlignment="Center" />
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>

                          <TextBlock Text="尚未选择目标座位"
                                     Classes="helper-text"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding HasNoSelectedSeats}" />
                        </Grid>
                      </Border>
                    </Grid>
                  </StackPanel>

                  <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="16">
                    <StackPanel Spacing="0">
                      <TextBlock Text="抢座执行策略"
                                 Classes="field-label" />
                      <ComboBox SelectedIndex="{Binding SelectedGrabReservationStrategyIndex}"
                                ItemsSource="{Binding GrabReservationStrategies}"
                                IsEnabled="{Binding CanEditGrabConfiguration}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="0">
                      <TextBlock Text="抢座模式"
                                 Classes="field-label" />
                      <ComboBox SelectedIndex="{Binding SelectedGrabModeIndex}"
                                ItemsSource="{Binding GrabModes}"
                                IsEnabled="{Binding CanEditGrabConfiguration}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Spacing="0">
                      <TextBlock Text="定时启动"
                                 Classes="field-label" />
                      <TextBox Text="{Binding ScheduledTimeText}"
                               Watermark="HH:mm:ss"
                               IsEnabled="{Binding CanEditGrabConfiguration}" />
                    </StackPanel>
                  </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="10"
                            Width="168">
                  <TextBlock Text="执行控制"
                             Classes="field-label" />
                  <Button Content="开始监控"
                          Command="{Binding StartGrabCommand}"
                          IsEnabled="{Binding CanEditGrabConfiguration}"
                          Background="{DynamicResource AppAccentBrush}"
                          Foreground="{DynamicResource AppAccentForegroundBrush}"
                          FontWeight="Bold"
                          HorizontalContentAlignment="Center" />
                  <Button Content="停止任务"
                          Command="{Binding StopGrabCommand}"
                          IsEnabled="{Binding IsGrabTaskActive}"
                          Classes="Danger"
                          HorizontalContentAlignment="Center" />
                </StackPanel>
              </Grid>
            </Border>

            <Grid Grid.Row="2"
                  RowDefinitions="Auto,*"
                  RowSpacing="16">
              <Grid ColumnDefinitions="*,*,*,*"
                    ColumnSpacing="14">
                <Border Classes="grab-stat-card Shadow">
                  <StackPanel Spacing="10">
                    <TextBlock Text="轮询总次数"
                               Classes="grab-stat-title" />
                    <TextBlock Text="{Binding GrabPollCount}"
                               Classes="grab-stat-value" />
                  </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Classes="grab-stat-card Shadow">
                  <StackPanel Spacing="10">
                    <TextBlock Text="已发请求数"
                               Classes="grab-stat-title" />
                    <TextBlock Text="{Binding GrabRequestCount}"
                               Classes="grab-stat-value" />
                  </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Classes="grab-stat-card Shadow">
                  <StackPanel Spacing="10">
                    <TextBlock Text="最近一次请求"
                               Classes="grab-stat-title" />
                    <TextBlock Text="{Binding GrabLastRequestText}"
                               Classes="grab-stat-value"
                               FontSize="24" />
                  </StackPanel>
                </Border>

                <Border Grid.Column="3"
                        Classes="grab-stat-card Shadow">
                  <StackPanel Spacing="10">
                    <TextBlock Text="任务运行时长"
                               Classes="grab-stat-title" />
                    <TextBlock Text="{Binding GrabRuntimeText}"
                               Classes="grab-stat-value" />
                  </StackPanel>
                </Border>
              </Grid>

              <Border Grid.Row="1"
                      Classes="semi-card Shadow"
                      Padding="20">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="12">
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="12">
                    <StackPanel Spacing="2">
                      <TextBlock Text="抢座实时日志"
                                 FontSize="18"
                                 FontWeight="Bold" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Padding="10,6"
                            CornerRadius="999"
                            Background="{DynamicResource SemiColorFill0}"
                            BorderBrush="{DynamicResource SemiCardBorderBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                      <TextBlock Text="{Binding GrabDashboardStatusText}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Foreground="{Binding GrabDashboardStatusBrush}" />
                    </Border>
                  </Grid>

                  <Border Grid.Row="1"
                          Background="{DynamicResource SemiColorFill0}"
                          BorderBrush="{DynamicResource SemiCardBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="18"
                          Padding="16">
                    <ScrollViewer x:Name="GrabLogScrollViewer"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                      <SelectableTextBlock Text="{Binding GrabLogsText}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SemiTextPrimaryBrush}"
                                           FontFamily="Consolas, Cascadia Mono, Monaco, monospace"
                                           FontSize="12.5" />
                    </ScrollViewer>
                  </Border>
                </Grid>
              </Border>
            </Grid>
          </Grid>

        <!-- Tab 3: Occupy -->
        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="24" Margin="0,0,16,0" Background="Transparent">
          <TextBlock Classes="page-title" Text="占座" Margin="0,0,0,16" />

          <Border Grid.Row="1"
                  Classes="semi-card Shadow"
                  Background="{DynamicResource SemiCardBackgroundBrush}"
                  Padding="28">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="32" RowSpacing="20">
              <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Top">
                <TextBlock Classes="hero-title" Text="{Binding ReservationHeroTitle}" VerticalAlignment="Center" />
                <Label Content="运行中"
                       Theme="{DynamicResource TagLabel}"
                       Classes="Green"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsOccupyRunning}" />
                <Label Content="已停止"
                       Theme="{DynamicResource TagLabel}"
                       Classes="Grey"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsOccupyStopped}" />
              </StackPanel>

              <WrapPanel Grid.Row="1"
                         Grid.Column="1"
                         Orientation="Horizontal"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Bottom">
                <Button Content="手动刷新"
                        Command="{Binding RefreshReservationCommand}"
                        Classes="Secondary"
                        Margin="0,0,12,8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center" />
                <Button Content="停止占座"
                        Command="{Binding StopOccupyCommand}"
                        Classes="Danger"
                        Margin="0,0,12,8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center" />
                <Button Content="开始占座"
                        Command="{Binding StartOccupyCommand}"
                        Background="{DynamicResource AppAccentBrush}"
                        Foreground="{DynamicResource AppAccentForegroundBrush}"
                        FontWeight="Bold"
                        Margin="0,0,12,8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center" />
              </WrapPanel>

              <Grid Grid.Row="1" Grid.Column="0" ColumnDefinitions="*,*" ColumnSpacing="28" VerticalAlignment="Bottom">
                <StackPanel Spacing="4">
                  <TextBlock Text="座位过期时间"
                             FontSize="12"
                             Foreground="{DynamicResource SemiColorText2}" />
                  <TextBlock Text="{Binding ReservationExpiryText}"
                             FontSize="20"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource SemiColorText0}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="取消座位预约倒计时"
                             FontSize="12"
                             Foreground="{DynamicResource SemiColorText2}" />
                  <TextBlock Text="{Binding ReservationCountdownText}"
                             FontSize="20"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource SemiColorText0}" />
                </StackPanel>
              </Grid>
            </Grid>
          </Border>

          <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="24" Background="Transparent">
            <Border Classes="semi-card Shadow">
              <Grid RowDefinitions="Auto,*" RowSpacing="16">
                <TextBlock Classes="section-title" Text="策略设置" Margin="0" />
                <StackPanel Grid.Row="1" Spacing="20">
                  <StackPanel Spacing="0">
                    <TextBlock Classes="field-label" Text="轮询刷新频率" />
                    <ComboBox SelectedIndex="{Binding SelectedRefreshModeIndex}"
                              ItemsSource="{Binding RefreshModes}"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>

                  <StackPanel Spacing="0">
                    <TextBlock Classes="field-label" Text="重新预约间隔时间" />
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                      <NumericUpDown Minimum="1"
                                     Maximum="1800"
                                     Increment="1"
                                     ClipValueToMinMax="True"
                                     ParsingNumberStyle="Integer"
                                     Value="{Binding ReReserveDelaySeconds}"
                                     FormatString="0"
                                     TextInput="OnUnsignedIntegerNumericUpDownTextInput"
                                     KeyDown="OnUnsignedIntegerNumericUpDownKeyDown"
                                     HorizontalAlignment="Stretch" />
                      <TextBlock Grid.Column="1"
                                 Text="秒"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource SemiTextSecondaryBrush}"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>

            <Border Grid.Column="1" Classes="semi-card Shadow">
              <Grid RowDefinitions="Auto,*" RowSpacing="16">
                <TextBlock Classes="section-title" Text="占座实时日志" Margin="0" />
                <Border Grid.Row="1"
                        Background="{DynamicResource SemiColorFill0}"
                        CornerRadius="16"
                        BorderBrush="{DynamicResource SemiCardBorderBrush}"
                        BorderThickness="1"
                        Padding="16">
                  <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto"
                                x:Name="OccupyLogScrollViewer">
                    <ItemsControl ItemsSource="{Binding OccupyLogLines}" />
                  </ScrollViewer>
                </Border>
              </Grid>
            </Border>
          </Grid>
        </Grid>

        <!-- Tab 4: Notification Settings -->
        <ScrollViewer>
          <StackPanel Spacing="24"
                      Margin="0,0,16,0"
                      HorizontalAlignment="Stretch">
            <TextBlock Classes="page-title" Text="通知设置" Margin="0" />
            <Border Classes="semi-card Shadow">
              <Grid RowDefinitions="Auto,Auto"
                    RowSpacing="24">
                <StackPanel Spacing="10">
                  <Border Background="{DynamicResource DashboardMutedSurfaceBrush}"
                          BorderBrush="{DynamicResource SemiCardBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="999"
                          Padding="5"
                          Width="{Binding NotificationSegmentControlWidth}"
                          HorizontalAlignment="Center">
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="6"
                          ClipToBounds="True">
                      <Border Background="{DynamicResource AppNotificationSegmentThumbBrush}"
                              Width="{Binding NotificationSegmentSliderWidth}"
                              CornerRadius="999"
                              BoxShadow="0 2 10 0 #120F172A"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Stretch"
                              IsHitTestVisible="False">
                        <Border.RenderTransform>
                          <TranslateTransform X="{Binding NotificationSegmentSliderOffset}">
                            <TranslateTransform.Transitions>
                              <Transitions>
                                <DoubleTransition Property="X"
                                                  Duration="0:0:0.26"
                                                  Easing="CircularEaseOut" />
                              </Transitions>
                            </TranslateTransform.Transitions>
                          </TranslateTransform>
                        </Border.RenderTransform>
                      </Border>

                      <Grid Grid.Column="0">
                        <Button Classes="notification-segment"
                                Background="Transparent"
                                Foreground="{Binding EmailNotificationTabForegroundBrush}"
                                BorderThickness="0"
                                CornerRadius="999"
                                Content="邮件提醒配置"
                                Command="{Binding ShowEmailNotificationSettingsCommand}" />
                      </Grid>

                      <Grid Grid.Column="1">
                        <Button Classes="notification-segment"
                                Background="Transparent"
                                Foreground="{Binding LocalNotificationTabForegroundBrush}"
                                BorderThickness="0"
                                CornerRadius="999"
                                Content="本地弹窗提醒"
                                Command="{Binding ShowLocalNotificationSettingsCommand}" />
                      </Grid>
                    </Grid>
                  </Border>

                  <TextBlock Classes="helper-text"
                             HorizontalAlignment="Center"
                             Text="{Binding NotificationSettingsStatusText}" />
                </StackPanel>

                <Carousel Grid.Row="1"
                          SelectedIndex="{Binding SelectedNotificationSettingsTabIndex}"
                          HorizontalAlignment="Stretch">
                  <Carousel.PageTransition>
                    <CrossFade Duration="0:0:0.25" />
                  </Carousel.PageTransition>

                  <Grid HorizontalAlignment="Stretch">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          ColumnDefinitions="*,*"
                          RowSpacing="18"
                          ColumnSpacing="24"
                          HorizontalAlignment="Stretch">
                      <StackPanel Grid.Row="0"
                                  Grid.ColumnSpan="2"
                                  Spacing="0">
                        <TextBlock Classes="field-label"
                                   Text="SMTP 服务器地址（主机名）" />
                        <TextBox Text="{Binding CookieAlertSmtpHost}"
                                 Watermark="smtp.example.com"
                                 HorizontalAlignment="Stretch" />
                      </StackPanel>

                      <StackPanel Grid.Row="1"
                                  Grid.Column="0"
                                  Spacing="0">
                        <TextBlock Classes="field-label"
                                   Text="端口" />
                        <NumericUpDown Minimum="1"
                                       Maximum="65535"
                                       Increment="1"
                                       ClipValueToMinMax="True"
                                       ParsingNumberStyle="Integer"
                                       Value="{Binding CookieAlertSmtpPort}"
                                       FormatString="0"
                                       TextInput="OnUnsignedIntegerNumericUpDownTextInput"
                                       KeyDown="OnUnsignedIntegerNumericUpDownKeyDown"
                                       HorizontalAlignment="Stretch" />
                      </StackPanel>

                      <StackPanel Grid.Row="1"
                                  Grid.Column="1"
                                  Spacing="0">
                        <TextBlock Classes="field-label"
                                   Text="安全性" />
                        <ComboBox ItemsSource="{Binding EmailSecurityModes}"
                                  SelectedIndex="{Binding SelectedCookieAlertSecurityModeIndex}"
                                  HorizontalAlignment="Stretch" />
                      </StackPanel>

                      <StackPanel Grid.Row="2"
                                  Grid.Column="0"
                                  Spacing="0">
                        <TextBlock Classes="field-label"
                                   Text="用户名" />
                        <TextBox Text="{Binding CookieAlertUsername}"
                                 Watermark="填写 SMTP 用户名"
                                 HorizontalAlignment="Stretch" />
                      </StackPanel>

                      <StackPanel Grid.Row="2"
                                  Grid.Column="1"
                                  Spacing="0">
                        <TextBlock Classes="field-label"
                                   Text="邮箱授权码/密码" />
                        <TextBox Text="{Binding CookieAlertPassword}"
                                 PasswordChar="●"
                                 Watermark="填写邮箱授权码或密码"
                                 HorizontalAlignment="Stretch" />
                      </StackPanel>

                      <StackPanel Grid.Row="3"
                                  Grid.Column="0"
                                  Spacing="0">
                        <TextBlock Classes="field-label"
                                   Text="发信人邮箱地址" />
                        <TextBox Text="{Binding CookieAlertFromAddress}"
                                 Watermark="sender@example.com"
                                 HorizontalAlignment="Stretch" />
                      </StackPanel>

                      <StackPanel Grid.Row="3"
                                  Grid.Column="1"
                                  Spacing="0">
                        <TextBlock Classes="field-label"
                                   Text="收信人邮箱地址" />
                        <TextBox Text="{Binding CookieAlertToAddress}"
                                 Watermark="receiver@example.com"
                                 HorizontalAlignment="Stretch" />
                      </StackPanel>

                      <Grid Grid.Row="4"
                            Grid.ColumnSpan="2"
                            ColumnDefinitions="*,Auto"
                            ColumnSpacing="16"
                            Margin="0,8,0,0">
                        <Border Classes="notify-toggle-card">
                          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                            <StackPanel Spacing="4">
                              <TextBlock FontSize="15"
                                         FontWeight="SemiBold"
                                         Text="开启邮件提醒" />
                              <TextBlock Classes="helper-text"
                                         Text="Cookie 失效后，会自动按上方 SMTP 参数向目标邮箱发送提醒邮件" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding CookieEmailAlertsEnabled}"
                                          OnContent="开"
                                          OffContent="关"
                                          VerticalAlignment="Center" />
                          </Grid>
                        </Border>

                        <Button Grid.Column="1"
                                Content="发送测试邮件"
                                Command="{Binding SendTestEmailAlertCommand}"
                                Background="{DynamicResource SemiAccentBrush}"
                                Foreground="{DynamicResource AppAccentForegroundBrush}"
                                MinWidth="160" />
                      </Grid>
                    </Grid>
                  </Grid>

                  <Grid HorizontalAlignment="Stretch">
                    <StackPanel Spacing="18"
                                HorizontalAlignment="Stretch">
                      <Border Classes="notify-toggle-card">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                          <StackPanel Spacing="4">
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="开启屏幕右下角通知" />
                            <TextBlock Classes="helper-text"
                                       Text="当检测到 Cookie 已失效时，使用 Toast 弹窗形式，在屏幕右下角弹出提醒。即使你正在浏览其他网页，也能看到这一角的弹窗" />
                          </StackPanel>
                          <ToggleSwitch Grid.Column="1"
                                        IsChecked="{Binding CookieLocalToastEnabled}"
                                        OnContent="开"
                                        OffContent="关"
                                        VerticalAlignment="Center" />
                        </Grid>
                      </Border>

                      <Border Classes="notify-toggle-card">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                          <StackPanel Spacing="4">
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="开启提示音" />
                            <TextBlock Classes="helper-text"
                                       Text="开启后，Toast 弹窗在弹出时会同时播放提示音，用于在后台工作时更快感知授权失效。" />
                          </StackPanel>
                          <ToggleSwitch Grid.Column="1"
                                        IsChecked="{Binding CookieLocalSoundEnabled}"
                                        OnContent="开"
                                        OffContent="关"
                                        VerticalAlignment="Center" />
                        </Grid>
                      </Border>

                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="16"
                            Margin="0,8,0,0">
                        <Border Classes="notify-toggle-card">
                          <StackPanel Spacing="6">
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="发送测试通知" />
                            <TextBlock Classes="helper-text"
                                       Text="点击后立即在屏幕右下角弹出自定义 Toast" />
                          </StackPanel>
                        </Border>

                        <Button Grid.Column="1"
                                Content="发送测试通知"
                                Command="{Binding SendTestLocalAlertCommand}"
                                Background="{DynamicResource SemiAccentBrush}"
                                Foreground="{DynamicResource AppAccentForegroundBrush}"
                                MinWidth="160" />
                      </Grid>
                    </StackPanel>
                  </Grid>
                </Carousel>
              </Grid>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <!-- Tab 5: Settings -->
        <ScrollViewer>
          <StackPanel Spacing="24" Margin="0,0,16,0">
            <TextBlock Classes="page-title" Text="系统设置" />
            
            <Grid ColumnDefinitions="*,*" ColumnSpacing="24">
              <StackPanel Spacing="24">
                <Border Classes="card">
                  <StackPanel Spacing="16">
                    <TextBlock Classes="section-title" Text="常规体验" />
                    <CheckBox Content="屏幕右下角展示应用横幅通知" IsChecked="{Binding NotificationsEnabled}" />
                    <CheckBox Content="当任务进行时，右上角关闭会最小化到托盘" IsChecked="{Binding MinimizeToTrayEnabled}" />
                    <CheckBox Content="自定义接口地址和查询语法" IsChecked="{Binding CustomApiOverridesEnabled}" FontWeight="Bold" Foreground="{DynamicResource SemiWarningTextBrush}"/>
                    
                    <Separator Background="{DynamicResource AppSeparatorBrush}" Margin="0,8"/>
                    
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                      <StackPanel Spacing="8">
                        <TextBlock Text="网络 API 超时阈值（秒）" FontSize="13" Opacity="0.8"/>
                        <NumericUpDown Minimum="3" Maximum="60" Value="{Binding ApiTimeoutSeconds}" HorizontalAlignment="Stretch"/>
                      </StackPanel>
                      <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="断线恢复重试次数（次）" FontSize="13" Opacity="0.8"/>
                        <NumericUpDown Minimum="1" Maximum="10" Value="{Binding RetryCount}" HorizontalAlignment="Stretch"/>
                      </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                      <StackPanel Spacing="8">
                        <TextBlock Classes="field-label" Text="界面主题" />
                        <ComboBox ItemsSource="{Binding ThemeModes}"
                                  SelectedIndex="{Binding SelectedAppThemeModeIndex}" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Classes="field-label" Text="强调色来源" />
                        <CheckBox Content="跟随系统主题色"
                                  IsChecked="{Binding UseSystemAccent}" />
                      </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,16,0,0">
                      <Button Content="💾 保存设置"
                              Command="{Binding SaveSettingsCommand}"
                              Background="{DynamicResource AppAccentBrush}"
                              Foreground="{DynamicResource AppAccentForegroundBrush}"
                              FontWeight="Bold"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Center" />
                      <Button Grid.Column="1"
                              Content="测试Toast通知"
                              Command="{Binding TestToastCommand}"
                              Classes="Secondary"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Center" />
                    </Grid>
                  </StackPanel>
                </Border>
              </StackPanel>

              <Border Classes="card" Grid.Column="1" IsVisible="{Binding CustomApiOverridesEnabled}" BorderBrush="{DynamicResource AppWarningBorderBrush}">
                <StackPanel Spacing="16">
                  <TextBlock Classes="section-title" Text="⚠️ 自定义接口地址和查询语法" Foreground="{DynamicResource SemiWarningTextBrush}" />
                  <TextBlock Text="如果你使用的不是官方地址，如学校自建等，请自行抓包替换" FontSize="13" Opacity="0.7" TextWrapping="Wrap" />
                  
                  <ScrollViewer MaxHeight="400">
                     <StackPanel Spacing="16" Margin="0,0,16,0">
                        <TextBlock Text="获取Cookie地址 (替换模板中的ReplaceMeByCode)" FontSize="13" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding GetCookieTemplateText}" AcceptsReturn="True" MinHeight="72" TextWrapping="Wrap" FontFamily="Consolas, monospace" FontSize="11"/>
                        
                        <TextBlock Text="列出所有可用场馆模板" FontSize="13" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding QueryLibrariesTemplateText}" AcceptsReturn="True" MinHeight="90" TextWrapping="Wrap" FontFamily="Consolas, monospace" FontSize="11"/>
                        
                        <TextBlock Text="获取指定场馆所有座位信息模板" FontSize="13" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding QueryLibraryLayoutTemplateText}" AcceptsReturn="True" MinHeight="90" TextWrapping="Wrap" FontFamily="Consolas, monospace" FontSize="11"/>

                        <TextBlock Text="查询指定场馆规则模板" FontSize="13" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding QueryLibraryRuleTemplateText}" AcceptsReturn="True" MinHeight="90" TextWrapping="Wrap" FontFamily="Consolas, monospace" FontSize="11"/>
                        
                        <TextBlock Text="获取当前预约信息模板" FontSize="13" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding QueryReservationInfoTemplateText}" AcceptsReturn="True" MinHeight="100" TextWrapping="Wrap" FontFamily="Consolas, monospace" FontSize="11"/>
                        
                        <TextBlock Text="预约指定座位模板" FontSize="13" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding ReserveSeatTemplateText}" AcceptsReturn="True" MinHeight="90" TextWrapping="Wrap" FontFamily="Consolas, monospace" FontSize="11"/>
                        
                        <TextBlock Text="取消当前预约模板" FontSize="13" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding CancelReservationTemplateText}" AcceptsReturn="True" MinHeight="90" TextWrapping="Wrap" FontFamily="Consolas, monospace" FontSize="11"/>
                     </StackPanel>
                  </ScrollViewer>

                  <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                    <Button Content="✅ 应用至程序" Command="{Binding SaveProtocolOverridesCommand}" Background="{DynamicResource SemiWarningSoftBrush}" Foreground="{DynamicResource SemiWarningTextBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="🔄 恢复默认" Command="{Binding ResetProtocolOverridesCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                  </Grid>
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </Carousel>

      <Border Grid.Row="1"
              ZIndex="30"
              IsVisible="{Binding IsGrabSeatSelectionOverlayOpen}"
              Background="{DynamicResource AppModalOverlayBrush}"
              PointerPressed="OnGrabSeatOverlayPointerPressed">
        <Grid Margin="28,16,28,28">
          <Border Classes="semi-card Shadow"
                  MaxWidth="1180"
                  MaxHeight="760"
                  Padding="24"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  PointerPressed="OnGrabSeatModalPointerPressed">
            <Grid RowDefinitions="Auto,Auto,*,Auto"
                  RowSpacing="18">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">
                <StackPanel Spacing="4">
                  <TextBlock Text="选择目标座位"
                             FontSize="22"
                             FontWeight="Bold" />
                  <TextBlock Text="{Binding DraftSelectedSeatSummaryText}"
                             Classes="helper-text" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="关闭 (X)"
                        Command="{Binding CancelGrabSeatSelectionCommand}"
                        Classes="Secondary"
                        HorizontalContentAlignment="Center" />
              </Grid>

              <Grid Grid.Row="1"
                    ColumnDefinitions="2.1*,Auto,Auto,Auto"
                    ColumnSpacing="12">
                <TextBox Text="{Binding SeatFilterText}"
                         Watermark="仅按座位号过滤"
                         VerticalAlignment="Center" />
                <CheckBox Grid.Column="1"
                          Content="隐藏被占座位"
                          IsChecked="{Binding ShowAvailableOnly}"
                          VerticalAlignment="Center" />
                <Button Grid.Column="2"
                        Content="刷新"
                        Command="{Binding RefreshSeatsCommand}"
                        Classes="Secondary"
                        HorizontalContentAlignment="Center" />
                <Button Grid.Column="3"
                        Content="收藏选中座位"
                        Command="{Binding SaveFavoritesCommand}"
                        Classes="Secondary"
                        HorizontalContentAlignment="Center" />
              </Grid>

              <Border Grid.Row="2"
                      Background="{DynamicResource SemiColorFill0}"
                      BorderBrush="{DynamicResource SemiCardBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="18"
                      Padding="16">
                <Grid>
                  <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto"
                                IsVisible="{Binding HasSeatLayout}">
                    <ItemsControl ItemsSource="{Binding VisibleSeats}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                    </ItemsControl>
                  </ScrollViewer>

                  <Border Background="{DynamicResource AppOverlaySurfaceStrongBrush}"
                          CornerRadius="14"
                          Padding="24"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          IsVisible="{Binding HasNoSeatLayout}">
                    <TextBlock Text="当前场馆暂无可编辑的座位布局，请先刷新或重新绑定场馆。"
                               Classes="helper-text"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                  </Border>

                  <Border Background="{DynamicResource AppOverlaySurfaceStrongBrush}"
                          CornerRadius="14"
                          Padding="24"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowSeatFilterEmptyState}">
                    <TextBlock Text="当前筛选条件下没有可显示的座位。"
                               Classes="helper-text"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                  </Border>

                  <Border Background="{DynamicResource AppOverlaySurfaceSoftBrush}"
                          CornerRadius="16"
                          IsVisible="{Binding IsApplyingSeatFilter}">
                    <StackPanel Width="220"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="10">
                      <ProgressBar IsIndeterminate="True"
                                   Height="4"
                                   Foreground="{DynamicResource SemiAccentBrush}" />
                      <TextBlock Text="正在应用筛选并刷新座位工作区..."
                                 Classes="helper-text"
                                 HorizontalAlignment="Center"
                                 TextAlignment="Center" />
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>

              <Grid Grid.Row="3"
                    ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">
                <TextBlock Text="只有点击“确认完成”才会同步本次勾选结果；直接关闭或点击遮罩空白处会放弃本次修改。"
                           Classes="helper-text"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="确认完成"
                        Command="{Binding ConfirmGrabSeatSelectionCommand}"
                        Background="{DynamicResource AppAccentBrush}"
                        Foreground="{DynamicResource AppAccentForegroundBrush}"
                        FontWeight="Bold"
                        HorizontalContentAlignment="Center" />
              </Grid>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <Border Grid.Row="1"
              ZIndex="20"
              IsVisible="{Binding IsVenuePickerOpen}"
              Background="{DynamicResource AppBackdropOverlayBrush}">
        <Grid HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Margin="24,8,24,24">
          <Border Classes="semi-card Shadow"
                  Width="400"
                  MaxWidth="400"
                  MaxHeight="600"
                  Padding="20"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
            <Grid RowDefinitions="Auto,*" RowSpacing="16">
              <Grid Grid.Row="0" RowDefinitions="Auto,Auto" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                  <TextBlock Text="选择作业场馆"
                             FontSize="20"
                             FontWeight="Bold"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="1"
                          Content="关闭"
                          Command="{Binding CloseVenuePickerCommand}"
                          Classes="Secondary"
                          HorizontalContentAlignment="Center" />
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="下方已自动刷新最新场馆列表，点击一个场馆后，Dashboard 会立即刷新为该场馆预览。"
                           Classes="helper-text" />
              </Grid>

              <Border Grid.Row="1"
                      Background="{DynamicResource SemiColorFill0}"
                      BorderBrush="{DynamicResource SemiCardBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="14"
                      Padding="8"
                      VerticalAlignment="Stretch">
                <ListBox ItemsSource="{Binding AvailableLibraries}"
                         SelectedItem="{Binding SelectedLibrary}"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalAlignment="Stretch"
                         Margin="0,12">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="*,Auto"
                            Margin="4"
                            MinHeight="72"
                            PointerReleased="OnVenuePickerItemPointerReleased">
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding Floor}"
                                     FontSize="12"
                                     Foreground="{DynamicResource SemiColorText2}" />
                          <TextBlock FontSize="12"
                                     Foreground="{DynamicResource SemiColorText2}">
                            <Run Text="总座 " />
                            <Run Text="{Binding SeatsTotal}" />
                            <Run Text=" · 已占用 " />
                            <Run Text="{Binding SeatsUsed}" />
                            <Run Text=" · 已预定 " />
                            <Run Text="{Binding SeatsBooking}" />
                          </TextBlock>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Theme="{DynamicResource TagLabel}"
                                Classes="Green"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsOpen}">
                          <TextBlock Text="开放中" />
                        </Border>
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Border>

            </Grid>
          </Border>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>



